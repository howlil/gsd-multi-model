{
  "name": "@howlil/ez-agents",
  "version": "4.0.0",
  "description": "EZ Agents — Meta-prompting with multi-model support (Qwen, Kimi, OpenAI)",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "ez-agents": "dist/bin/install.js",
    "ez-agents-update": "dist/bin/update.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./factories": {
      "types": "./dist/lib/factories/index.d.ts",
      "import": "./dist/lib/factories/index.js"
    },
    "./strategies": {
      "types": "./dist/lib/strategies/index.d.ts",
      "import": "./dist/lib/strategies/index.js"
    },
    "./adapters": {
      "types": "./dist/lib/adapters/index.d.ts",
      "import": "./dist/lib/adapters/index.js"
    },
    "./observer": {
      "types": "./dist/lib/observer/index.d.ts",
      "import": "./dist/lib/observer/index.js"
    },
    "./decorators": {
      "types": "./dist/lib/decorators/index.d.ts",
      "import": "./dist/lib/decorators/index.js"
    },
    "./facades": {
      "types": "./dist/lib/facades/index.d.ts",
      "import": "./dist/lib/facades/index.js"
    },
    "./commands": {
      "types": "./dist/lib/commands/index.d.ts",
      "import": "./dist/lib/commands/index.js"
    },
    "./services": {
      "types": "./dist/lib/services/index.d.ts",
      "import": "./dist/lib/services/index.js"
    },
    "./repositories": {
      "types": "./dist/lib/repositories/index.d.ts",
      "import": "./dist/lib/repositories/index.js"
    },
    "./fp": {
      "types": "./dist/lib/fp/index.d.ts",
      "import": "./dist/lib/fp/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "commands",
    "ez-agents",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli",
    "ez-agents",
    "agent-orchestration"
  ],
  "author": "TÂCHES",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howlil/ez-agents.git"
  },
  "homepage": "https://github.com/howlil/ez-agents",
  "bugs": {
    "url": "https://github.com/howlil/ez-agents/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "@types/micromatch": "4.0.0",
    "@types/node": "20.0.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "c8": "11.0.0",
    "complexity-report": "2.0.0-alpha",
    "dependency-cruiser": "17.3.9",
    "eslint": "8.57.0",
    "eslint-plugin-complexity": "1.0.2",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-tsdoc": "0.5.2",
    "expect-type": "1.3.0",
    "fast-check": "3.0.0",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "js-yaml": "4.1.1",
    "jscpd": "4.0.8",
    "jsdoc": "4.0.2",
    "k6": "0.0.0",
    "lint-staged": "15.5.2",
    "madge": "8.0.0",
    "markdownlint": "0.40.0",
    "ts-morph": "27.0.2",
    "ts-node": "10.9.0",
    "ts-prune": "0.10.3",
    "tsup": "8.0.0",
    "typedoc": "0.28.18",
    "typedoc-plugin-missing-exports": "4.1.2",
    "typescript": "5.4.5",
    "vitest": "4.1.0"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --noEmit --strict",
    "dev": "tsx bin/install.ts",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "build:hooks": "node --loader ts-node/esm scripts/build-hooks.ts",
    "prepublishOnly": "npm run build:hooks && npm run build",
    "test": "tsx scripts/run-tests.ts",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'bin/lib/**/*.ts' --exclude 'tests/**' --all tsx scripts/run-tests.ts",
    "test:a11y": "node tests/accessibility/run-a11y-tests.cjs",
    "test:qwen:code": "sh tests/staging/qwen-code-battle-full.sh",
    "test:qwen:code:simple": "sh tests/staging/qwen-code-simple-test.sh",
    "test:qwen:code:edge": "sh tests/staging/qwen-code-edge-cases.sh",
    "test:docker:qwen:code": "docker-compose -f docker-compose.staging.yml up --build ez-agents-qwen-code-battle",
    "test:docker:qwen:edge": "docker-compose -f docker-compose.staging.yml up --build ez-agents-qwen-code-edge-cases",
    "test:docker:all": "docker-compose -f docker-compose.staging.yml up --build --abort-on-container-exit",
    "install:production": "node --loader ts-node/esm scripts/install-production.ts",
    "install:production:latest": "node --loader ts-node/esm scripts/install-production.ts latest",
    "install:production:v4": "node --loader ts-node/esm scripts/install-production.ts 4.0.0",
    "validate:token": "node --loader ts-node/esm scripts/validate-token.ts",
    "security:scan": "npm audit --audit-level=moderate",
    "docs:generate": "jsdoc -c jsdoc.json -r bin/ ez-agents/bin/lib/",
    "docs:api": "typedoc",
    "analyze:duplicates": "jscpd --config .jscpd.json",
    "check:duplicates": "jscpd --config .jscpd.json",
    "check:complexity": "node --loader ts-node/esm scripts/check-complexity.ts",
    "check:tsdoc": "node --loader ts-node/esm scripts/check-tsdoc-coverage.ts",
    "test:package": "node --loader ts-node/esm scripts/test-package-docker.ts",
    "check:coupling": "madge --circular bin/lib/",
    "check:abstractions": "ts-prune",
    "check:all-metrics": "npm run lint && npm run check:duplicates && npm run check:coupling",
    "prepare": "husky",
    "gates:local": "node ez-agents/bin/lib/gate-executor.cjs --ci --cache",
    "gates:status": "node ez-agents/bin/lib/gate-executor.cjs --status",
    "gates:stats": "node ez-agents/bin/lib/gate-executor.cjs --stats",
    "deps:audit": "tsx bin/dependency-audit.ts",
    "deps:audit:json": "tsx bin/dependency-audit.ts --json",
    "deps:check": "tsx bin/dependency-audit.ts --quiet"
  },
  "lint-staged": {
    "*.ts": [
      "node --test"
    ],
    "*.md": [
      "tsx scripts/run-tests.ts"
    ]
  },
  "dependencies": {
    "micromatch": "4.0.5",
    "tiktoken": "1.0.22",
    "zod": "4.3.6"
  }
}
