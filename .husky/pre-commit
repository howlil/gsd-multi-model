#!/usr/bin/env sh

# EZ Agents Pre-commit Hook
# Runs security gate only (fast path - 2s timeout)

echo "Running pre-commit checks..."
echo "═══════════════════════════"
echo ""

# Build hooks first
echo "✓ Building hooks..."
npm run build:hooks || { echo "✗ Build failed. Commit aborted."; exit 1; }
echo ""

# Run security gate only (2s timeout)
echo "✓ Running security gate (gate-04)..."
node ez-agents/bin/lib/gate-executor.cjs --gate=gate-04 --timeout=2000 || {
  echo "✗ Security gate failed. Commit aborted."
  echo "  Use --no-verify to bypass (not recommended for security fixes)"
  exit 1
}
echo ""

echo "═══════════════════════════"
echo "✓ Pre-commit security check passed!"
exit 0
