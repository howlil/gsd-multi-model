{
  "git": {
    "branching_strategy": "phase",
    "phase_branch_template": "phase/{N}-{slug}",
    "milestone_branch_template": "ez/{milestone}-{slug}",
    "auto_create_phase_branches": true,
    "auto_merge_after_verification": true,
    "squash_milestone_branches": true,
    "merge_strategies": {
      "feature": "squash",
      "fix": "squash",
      "docs": "squash",
      "refactor": "squash",
      "phase": "merge",
      "release": "merge",
      "hotfix": "squash"
    },
    "validation": {
      "pre_commit": {
        "format": true,
        "lint": true,
        "test": false,
        "secret_detection": true,
        "validate_planning": true
      },
      "pre_merge": {
        "test_suite": "standard",
        "verify_planning_committed": true,
        "check_secrets": true,
        "validate_branch_naming": true
      },
      "pre_release": {
        "test_suite": "full",
        "security_scan": true,
        "performance_test": false,
        "dependency_audit": true
      }
    },
    "enterprise_mode": {
      "require_pull_request": false,
      "require_code_review": false,
      "required_reviewers": 1,
      "require_status_checks": true
    }
  },
  "workflow": {
    "_auto_chain_active": false
  },
  "packageManager": {
    "default": "npm",
    "autoDetect": true,
    "respectLockfile": true,
    "frozenLockfileInCI": true
  },
  "release": {
    "tier": "mvp",
    "tiers": {
      "mvp": {
        "moscow_scope": [
          "must"
        ],
        "coverage": 60,
        "git": "trunk",
        "checklist_items": 6
      },
      "medium": {
        "moscow_scope": [
          "must",
          "should"
        ],
        "coverage": 80,
        "git": "github-flow",
        "checklist_items": 18
      },
      "enterprise": {
        "moscow_scope": [
          "must",
          "should",
          "could"
        ],
        "coverage": 95,
        "git": "gitflow",
        "checklist_items": 30
      }
    }
  },
  "agent_discussion": {
    "enabled": true,
    "pre_flight_observer": true,
    "tech_lead_review": true,
    "scrum_master_standup": true,
    "_cost_warning": "agent_discussion adds ~2-3x token cost per phase. Disable specific agents via pre_flight_observer/tech_lead_review/scrum_master_standup flags."
  },
  "smart_orchestration": {
    "enabled": true,
    "_note": "Auto-invokes helper commands from core commands. Disable with --no-auto flag or set enabled: false.",
    "show_auto_prefix": true,
    "auto_invoke": {
      "execute_phase": {
        "pre": [
          "health"
        ],
        "post": [
          "verify-work"
        ],
        "conditional": {
          "if_tier_medium_plus_and_no_context": [
            "discuss-phase"
          ],
          "if_scope_creep_detected": [
            "add-todo"
          ]
        }
      },
      "plan_phase": {
        "conditional": {
          "if_phase_touches_sensitive_area": [
            "discuss-phase"
          ]
        }
      },
      "release": {
        "conditional": {
          "if_tier_medium": [
            "verify-work"
          ],
          "if_tier_enterprise": [
            "verify-work",
            "audit-milestone",
            "arch-review"
          ]
        }
      },
      "progress": {
        "pre": [
          "health"
        ]
      }
    }
  },
  "sessions": {
    "retention_policy": "manual",
    "auto_compress_threshold": 50,
    "compression_enabled": true,
    "export_format": "markdown",
    "sessions_directory": ".planning/sessions",
    "max_sessions_before_warning": 100,
    "chain_navigation_enabled": true
  },
  "observability": {
    "metrics": {
      "enabled": true,
      "provider": "prometheus",
      "prefix": "ez_",
      "port": 9091
    },
    "logging": {
      "enabled": true,
      "provider": "pino",
      "level": "info",
      "correlationIdHeader": "x-correlation-id"
    },
    "tracing": {
      "enabled": true,
      "provider": "jaeger",
      "serviceName": "ez-app",
      "serviceVersion": "1.0.0",
      "sampleRate": 0.1
    },
    "alerting": {
      "enabled": true,
      "provider": "alertmanager",
      "receivers": ["slack"]
    },
    "errorTracking": {
      "enabled": false,
      "provider": "sentry",
      "dsn": "",
      "environment": "production"
    }
  }
}