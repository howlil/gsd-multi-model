{
  "git": {
    "branching_strategy": "phase",
    "phase_branch_template": "phase/{N}-{slug}",
    "milestone_branch_template": "ez/{milestone}-{slug}",
    "auto_create_phase_branches": true,
    "auto_merge_after_verification": true,
    "squash_milestone_branches": true,
    "merge_strategies": {
      "feature": "squash",
      "fix": "squash",
      "docs": "squash",
      "refactor": "squash",
      "phase": "merge",
      "release": "merge",
      "hotfix": "squash"
    },
    "validation": {
      "pre_commit": {
        "format": true,
        "lint": true,
        "test": false,
        "secret_detection": true,
        "validate_planning": true
      },
      "pre_merge": {
        "test_suite": "standard",
        "verify_planning_committed": true,
        "check_secrets": true,
        "validate_branch_naming": true
      },
      "pre_release": {
        "test_suite": "full",
        "security_scan": true,
        "performance_test": false,
        "dependency_audit": true
      }
    },
    "enterprise_mode": {
      "require_pull_request": false,
      "require_code_review": false,
      "required_reviewers": 1,
      "require_status_checks": true
    }
  },
  "workflow": {
    "_auto_chain_active": false,
    "maxParallel": 5
  },
  "packageManager": {
    "default": "npm",
    "autoDetect": true,
    "respectLockfile": true,
    "frozenLockfileInCI": true
  },
  "release": {
    "tier": "mvp",
    "tiers": {
      "mvp": {
        "moscow_scope": [
          "must"
        ],
        "coverage": 60,
        "git": "trunk",
        "checklist_items": 6
      },
      "medium": {
        "moscow_scope": [
          "must",
          "should"
        ],
        "coverage": 80,
        "git": "github-flow",
        "checklist_items": 18
      },
      "enterprise": {
        "moscow_scope": [
          "must",
          "should",
          "could"
        ],
        "coverage": 95,
        "git": "gitflow",
        "checklist_items": 30
      }
    }
  },
  "agent_discussion": {
    "enabled": true,
    "pre_flight_observer": true,
    "tech_lead_review": true,
    "scrum_master_standup": true,
    "_cost_warning": "agent_discussion adds ~2-3x token cost per phase. Disable specific agents via pre_flight_observer/tech_lead_review/scrum_master_standup flags."
  },
  "smart_orchestration": {
    "enabled": true,
    "_note": "Auto-invokes helper commands from core commands. Disable with --no-auto flag or set enabled: false.",
    "show_auto_prefix": true,
    "auto_invoke": {
      "execute_phase": {
        "pre": [
          "health"
        ],
        "post": [
          "verify-work"
        ],
        "conditional": {
          "if_tier_medium_plus_and_no_context": [
            "discuss-phase"
          ],
          "if_scope_creep_detected": [
            "add-todo"
          ]
        }
      },
      "plan_phase": {
        "conditional": {
          "if_phase_touches_sensitive_area": [
            "discuss-phase"
          ]
        }
      },
      "release": {
        "conditional": {
          "if_tier_medium": [
            "verify-work"
          ],
          "if_tier_enterprise": [
            "verify-work",
            "audit-milestone",
            "arch-review"
          ]
        }
      },
      "progress": {
        "pre": [
          "health"
        ]
      }
    }
  },
  "sessions": {
    "retention_policy": "manual",
    "auto_compress_threshold": 50,
    "compression_enabled": true,
    "export_format": "markdown",
    "sessions_directory": ".planning/sessions",
    "max_sessions_before_warning": 100,
    "chain_navigation_enabled": true
  },
  "observability": {
    "metrics": {
      "enabled": true,
      "provider": "prometheus",
      "prefix": "ez_",
      "port": 9091
    },
    "logging": {
      "enabled": true,
      "provider": "pino",
      "level": "info",
      "correlationIdHeader": "x-correlation-id"
    },
    "tracing": {
      "enabled": true,
      "provider": "jaeger",
      "serviceName": "ez-app",
      "serviceVersion": "1.0.0",
      "sampleRate": 0.1
    },
    "alerting": {
      "enabled": true,
      "provider": "alertmanager",
      "receivers": ["slack"]
    },
    "errorTracking": {
      "enabled": false,
      "provider": "sentry",
      "dsn": "",
      "environment": "production"
    }
  },
  "documentation": {
    "enabled": true,
    "auto_generate": {
      "changelog": true,
      "adr_index": true,
      "api_docs": false,
      "user_docs": false
    },
    "directories": {
      "adr": "docs/adr",
      "runbooks": "docs/runbooks",
      "troubleshooting": "docs/troubleshooting",
      "api": "docs/api",
      "user_guide": "docs/user-guide",
      "schema": "docs/schema",
      "integrations": "docs/integrations"
    },
    "retention": {
      "changelog_versions": 10,
      "adr_retain_deprecated": true,
      "runbook_history": 20
    },
    "validation": {
      "min_health_score": 70,
      "check_staleness_days": 30,
      "required_files": [
        "CHANGELOG.md",
        "docs/adr/README.md"
      ]
    }
  },
  "analytics": {
    "provider": "posthog",
    "apiKey": "${POSTHOG_API_KEY}",
    "apiHost": "https://app.posthog.com",
    "consentRequired": true,
    "defaultConsent": {
      "analytics": false,
      "marketing": false,
      "functional": true
    },
    "funnels": {
      "user_onboarding": {
        "stages": [
          { "name": "page_view", "event": "landing_page_viewed", "optional": false },
          { "name": "signup", "event": "user_signed_up", "optional": false },
          { "name": "activation", "event": "onboarding_completed", "optional": false },
          { "name": "conversion", "event": "purchase_completed", "optional": false }
        ]
      }
    }
  },
  "experiments": {
    "provider": "posthog",
    "apiKey": "${POSTHOG_API_KEY}",
    "apiHost": "https://app.posthog.com",
    "experiments": {
      "pricing_page_test": {
        "goalEvent": "purchase_completed",
        "variants": ["control", "variant_a", "variant_b"],
        "minimumSampleSize": 1000,
        "significanceLevel": 0.05,
        "trafficAllocation": 0.5,
        "hypothesis": "Changing pricing display will increase conversions"
      }
    }
  },
  "featureFlags": {
    "provider": "flagsmith",
    "apiKey": "${FLAGSMITH_API_KEY}",
    "apiHost": "https://edge.api.flagsmith.com/api/v1/",
    "enableLocalEvaluation": true,
    "flags": {
      "new_checkout_flow": {
        "enabled": true,
        "rolloutPercentage": 50,
        "targeting": {
          "country": ["US", "CA", "UK"],
          "plan": ["pro", "enterprise"]
        }
      },
      "dark_mode": {
        "enabled": true,
        "rolloutPercentage": 100,
        "multivariate": {
          "control": "#FFFFFF",
          "variant_a": "#1A1A1A",
          "variant_b": "#0D1117"
        }
      }
    }
  },
  "cost_tracking": {
    "enabled": true,
    "budget": null,
    "warning_threshold": 80,
    "alert_thresholds": [50, 75, 90],
    "alert_channels": ["log", "file"],
    "auto_pause": false,
    "model_downgrade": {
      "enabled": true,
      "tiers": {
        "claude": {
          "premium": ["claude-3-opus", "claude-sonnet-4-6"],
          "standard": ["claude-3-sonnet"],
          "economy": ["claude-3-haiku"]
        },
        "openai": {
          "premium": ["gpt-4", "gpt-4-turbo"],
          "standard": ["gpt-3.5-turbo"],
          "economy": ["gpt-3.5-turbo"]
        },
        "qwen": {
          "premium": ["qwen-max"],
          "standard": ["qwen-plus"],
          "economy": ["qwen-turbo"]
        },
        "kimi": {
          "premium": ["kimi-v1-32k"],
          "standard": ["kimi-v1-8k"],
          "economy": ["kimi-v1-8k"]
        }
      }
    },
    "rates": {
      "claude-3": { "input": 0.003, "output": 0.015 },
      "claude-sonnet-4-6": { "input": 0.003, "output": 0.015 },
      "gpt-4": { "input": 0.03, "output": 0.06 },
      "qwen": { "input": 0.002, "output": 0.006 },
      "kimi": { "input": 0.002, "output": 0.006 }
    }
  },
  "circuit_breaker": {
    "enabled": true,
    "failure_threshold": 5,
    "reset_timeout": 60000,
    "persist_state": true,
    "metrics_enabled": true
  }
}